// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id Int @id @default(autoincrement())

  name     String
  email    String @unique
  password String

  role Role

  companyId Int?
  company   Company? @relation(fields: [companyId], references: [id])

  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id])

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  mr        MR?
}

enum Role {
  SUPER_ADMIN
  ADMIN
  WAREHOUSE_MANAGER
  ACCOUNTANT
  DISTRIBUTOR
  RETAILER
  MEDICAL_REPRESENTATIVE
}

model Company {
  id Int @id @default(autoincrement())

  name    String
  email   String?
  phone   String?
  address String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  branches   Branch[]
  warehouses Warehouse[]

  rolePermissions RolePermission[]

  permissions CompanyFeaturePermission[]

  products Product[]
}

model Branch {
  id Int @id @default(autoincrement())

  name String
  code String?

  address String?
  city    String?

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  users User[]

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Module {
  id Int @id @default(autoincrement())

  name        String  @unique
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  features Feature[]
}

model Feature {
  id Int @id @default(autoincrement())

  name        String
  description String?

  moduleId Int
  module   Module @relation(fields: [moduleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rolePermissions RolePermission[]

  permissions CompanyFeaturePermission[]
}

model CompanyFeaturePermission {
  id Int @id @default(autoincrement())

  companyId Int
  featureId Int

  enabled Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id])
  feature Feature @relation(fields: [featureId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, featureId])
}

model RolePermission {
  id Int @id @default(autoincrement())

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  role Role

  featureId Int
  feature   Feature @relation(fields: [featureId], references: [id])

  createdAt DateTime @default(now())
}

model ProductCategory {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id Int @id @default(autoincrement())

  name String
  code String @unique

  categoryId Int
  category   ProductCategory @relation(fields: [categoryId], references: [id])

  hsnCode String?
  gst     Float?

  mrp Float
  ptr Float?
  pts Float?
  ptd Float?

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  minStock Int

  batches Batch[]

  invoiceItems InvoiceItem[]

  retailerOrderItems RetailerOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Batch {
  id Int @id @default(autoincrement())

  batchNumber String @unique

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  manufacturingDate DateTime
  expiryDate        DateTime

  quantity Int

  inventories        Inventory[]
  warehouseTransfers WarehouseTransfer[]
  dispatches         Dispatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Inventory {
  id Int @id @default(autoincrement())

  batchId     Int
  warehouseId Int
  quantity    Int

  batch Batch @relation(fields: [batchId], references: [id])

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  stockMovements StockMovement[]
}

model Warehouse {
  id Int @id @default(autoincrement())

  name    String
  code    String  @unique
  address String?

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  inventories Inventory[]

  dispatches Dispatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StockMovement {
  id Int @id @default(autoincrement())

  inventoryId Int

  inventory Inventory @relation(fields: [inventoryId], references: [id])

  movementType String

  quantity Int

  remarks String?

  createdAt DateTime @default(now())
}

model WarehouseTransfer {
  id Int @id @default(autoincrement())

  batchId Int

  fromWarehouseId Int
  toWarehouseId   Int

  quantity Int

  remarks String?

  createdAt DateTime @default(now())

  batch Batch @relation(fields: [batchId], references: [id])
}

model Dispatch {
  id Int @id @default(autoincrement())

  batchId Int
  batch   Batch @relation(fields: [batchId], references: [id])

  warehouseId Int
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  customerName String

  quantity Int

  dispatchDate DateTime @default(now())

  status String @default("PENDING")

  remarks String?

  transportChallans TransportChallan[]

  createdAt DateTime @default(now())
}

model TransportChallan {
  id Int @id @default(autoincrement())

  dispatchId Int

  dispatch Dispatch @relation(fields: [dispatchId], references: [id])

  transporterName String

  vehicleNumber String

  driverName String?

  driverMobile String?

  challanNumber String @unique

  lrTrackings LRTracking[]

  createdAt DateTime @default(now())
}

model LRTracking {
  id Int @id @default(autoincrement())

  transportChallanId Int

  transportChallan TransportChallan @relation(fields: [transportChallanId], references: [id])

  lrNumber String @unique

  source String

  destination String

  status String @default("IN_TRANSIT")

  deliveryTrackings DeliveryTracking[]

  createdAt DateTime @default(now())
}

model DeliveryTracking {
  id Int @id @default(autoincrement())

  lrTrackingId Int

  lrTracking LRTracking @relation(fields: [lrTrackingId], references: [id])

  receiverName String

  receiverMobile String?

  deliveryDate DateTime @default(now())

  status String @default("DELIVERED")

  remarks String?

  createdAt DateTime @default(now())
}

model Stockist {
  id Int @id @default(autoincrement())

  name String

  code String @unique

  mobile String

  email String?

  address String?

  gstNumber String?

  drugLicenseNumber String?

  isActive Boolean @default(true)

  retailers Retailer[]

  createdAt DateTime @default(now())
}

model Retailer {
  id Int @id @default(autoincrement())

  stockistId Int

  stockist Stockist @relation(fields: [stockistId], references: [id])

  name String

  code String @unique

  mobile String

  email String?

  address String?

  gstNumber String?

  drugLicenseNumber String?

  invoices Invoice[]

  orders RetailerOrder[]

  ledgers Ledger[]

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
}

model Invoice {
  id Int @id @default(autoincrement())

  retailerId Int

  retailer Retailer @relation(fields: [retailerId], references: [id])

  invoiceNumber String @unique

  invoiceDate DateTime @default(now())

  subTotal Float

  gstAmount Float

  totalAmount Float

  status String @default("PENDING")

  invoiceItems InvoiceItem[]

  paymentCollections PaymentCollection[]

  createdAt DateTime @default(now())
}

model InvoiceItem {
  id Int @id @default(autoincrement())

  invoiceId Int

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  productId Int

  product Product @relation(fields: [productId], references: [id])

  quantity Int

  rate Float

  gst Float

  amount Float
}

model RetailerOrder {
  id         Int @id @default(autoincrement())
  retailerId Int

  retailer Retailer @relation(fields: [retailerId], references: [id])

  orderNumber String   @unique
  orderDate   DateTime @default(now())

  totalAmount Float

  status String @default("PENDING")

  orderItems RetailerOrderItem[]

  createdAt DateTime @default(now())
}

model RetailerOrderItem {
  id Int @id @default(autoincrement())

  retailerOrderId Int

  retailerOrder RetailerOrder @relation(fields: [retailerOrderId], references: [id])

  productId Int

  product Product @relation(fields: [productId], references: [id])

  quantity Int

  rate Float

  amount Float
}

model PaymentCollection {
  id Int @id @default(autoincrement())

  invoiceId Int

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  amount Float

  paymentMode String

  transactionRef String?

  paymentDate DateTime @default(now())

  remarks String?

  createdAt DateTime @default(now())
}

model Ledger {
  id Int @id @default(autoincrement())

  retailerId Int

  retailer Retailer @relation(fields: [retailerId], references: [id])

  transactionType String

  referenceNumber String

  debit Float @default(0)

  credit Float @default(0)

  balance Float

  remarks String?

  createdAt DateTime @default(now())
}

model Expense {
  id          Int      @id @default(autoincrement())
  expenseType String
  amount      Float
  remarks     String?
  expenseDate DateTime @default(now())
}

model Income {
  id         Int      @id @default(autoincrement())
  incomeType String
  amount     Float
  remarks    String?
  incomeDate DateTime @default(now())
}

model MR {
  id Int @id @default(autoincrement())

  userId Int? @unique
user   User? @relation(fields: [userId], references: [id])

  mrCode String @unique

  name String

  mobile String

  email String?

  territory String?

  joiningDate DateTime @default(now())

  status String @default("ACTIVE")

  attendances Attendance[]

  doctorVisits DoctorVisit[]

  chemistVisits ChemistVisit[]

  targets       Target[]
  tourPlans     TourPlan[]
  dailyReports  DailyReport[]
  meetings      Meeting[]
  followUps     FollowUp[]
  activities    Activity[]
  assignedLeads Lead[]
  leaveRequests LeaveRequest[]
  expenseClaims ExpenseClaim[]
  notifications Notification[]

  createdAt DateTime @default(now())
}

model Doctor {
  id Int @id @default(autoincrement())

  doctorCode String @unique

  name String

  specialization String?

  hospital String?

  mobile String?

  email String?

  address String?

  territory String?

  isActive Boolean @default(true)

  doctorVisits DoctorVisit[]

  meetingDoctors MeetingDoctor[]
  followUps      FollowUp[]

  createdAt DateTime @default(now())

  // doctorVisits DoctorVisit[]
  tourPlanDoctors TourPlanDoctor[]
  meetings        Meeting[]
}

model Chemist {
  id Int @id @default(autoincrement())

  chemistCode String @unique

  name String

  mobile String?

  email String?

  address String?

  territory String?

  gstNumber String?

  drugLicenseNumber String?

  isActive Boolean @default(true)

  chemistVisits ChemistVisit[]

  meetingChemists MeetingChemist[]
  followUps       FollowUp[]

  createdAt        DateTime          @default(now())
  tourPlanChemists TourPlanChemist[]
  meetings         Meeting[]
}

model Attendance {
  id Int @id @default(autoincrement())

  mrId Int

  mr MR @relation(fields: [mrId], references: [id])

  attendanceDate DateTime @default(now())

  checkInTime DateTime?

  checkOutTime DateTime?

  checkInLatitude Float?

  checkInLongitude Float?

  checkOutLatitude Float?

  checkOutLongitude Float?

  status String @default("PRESENT")

  createdAt DateTime @default(now())
}

model DoctorVisit {
  id Int @id @default(autoincrement())

  mrId Int

  doctorId Int

  visitDate DateTime @default(now())

  remarks String?

  productsDiscussed String?

  samplesGiven Int?

  latitude Float?

  longitude Float?

  mr MR @relation(fields: [mrId], references: [id])

  doctor Doctor @relation(fields: [doctorId], references: [id])

  createdAt DateTime @default(now())
}

model ChemistVisit {
  id Int @id @default(autoincrement())

  mrId Int

  chemistId Int

  visitDate DateTime @default(now())

  remarks String?

  productsDiscussed String?

  orderValue Float?

  latitude Float?

  longitude Float?

  mr MR @relation(fields: [mrId], references: [id])

  chemist Chemist @relation(fields: [chemistId], references: [id])

  createdAt DateTime @default(now())
}

model TourPlan {
  id Int @id @default(autoincrement())

  mrId Int

  tourDate DateTime

  territory String

  objective String?

  status String @default("PLANNED")

  createdAt DateTime @default(now())

  mr MR @relation(fields: [mrId], references: [id])

  tourPlanDoctors  TourPlanDoctor[]
  tourPlanChemists TourPlanChemist[]
}

model TourPlanDoctor {
  id Int @id @default(autoincrement())

  tourPlanId Int

  doctorId Int

  tourPlan TourPlan @relation(fields: [tourPlanId], references: [id])

  doctor Doctor @relation(fields: [doctorId], references: [id])
}

model TourPlanChemist {
  id Int @id @default(autoincrement())

  tourPlanId Int

  chemistId Int

  tourPlan TourPlan @relation(fields: [tourPlanId], references: [id])

  chemist Chemist @relation(fields: [chemistId], references: [id])
}

model DailyReport {
  id Int @id @default(autoincrement())

  mrId Int

  reportDate DateTime

  doctorVisits Int @default(0)

  chemistVisits Int @default(0)

  samplesDistributed Int @default(0)

  ordersCollected Decimal @default(0)

  remarks String?

  status String @default("SUBMITTED")

  createdAt DateTime @default(now())

  mr MR @relation(fields: [mrId], references: [id])
}

model Target {
  id Int @id @default(autoincrement())

  mrId Int

  month Int

  year Int

  doctorVisitTarget Int

  chemistVisitTarget Int

  orderTarget Decimal @default(0)

  achievedDoctorVisits Int @default(0)

  achievedChemistVisits Int @default(0)

  achievedOrderValue Decimal @default(0)

  status String @default("ACTIVE")

  createdAt DateTime @default(now())

  mr MR @relation(fields: [mrId], references: [id])
}

model Meeting {
  id Int @id @default(autoincrement())

  mrId Int

  doctorId Int?

  chemistId Int?

  title String

  description String?

  meetingDate DateTime

  location String?

  status String @default("SCHEDULED")

  createdAt DateTime @default(now())

  mr MR @relation(fields: [mrId], references: [id])

  doctor Doctor? @relation(fields: [doctorId], references: [id])

  chemist         Chemist?         @relation(fields: [chemistId], references: [id])
  meetingDoctors  MeetingDoctor[]
  meetingChemists MeetingChemist[]
  followUps       FollowUp[]
}

model MeetingDoctor {
  id Int @id @default(autoincrement())

  meetingId Int

  doctorId Int

  meeting Meeting @relation(fields: [meetingId], references: [id])

  doctor Doctor @relation(fields: [doctorId], references: [id])
}

model MeetingChemist {
  id Int @id @default(autoincrement())

  meetingId Int

  chemistId Int

  meeting Meeting @relation(fields: [meetingId], references: [id])

  chemist Chemist @relation(fields: [chemistId], references: [id])
}

model FollowUp {
  id Int @id @default(autoincrement())

  mrId Int

  doctorId Int?

  chemistId Int?

  meetingId Int?

  title String

  remarks String?

  followUpDate DateTime

  status String @default("PENDING")

  createdAt DateTime @default(now())

  mr MR @relation(fields: [mrId], references: [id])

  doctor Doctor? @relation(fields: [doctorId], references: [id])

  chemist Chemist? @relation(fields: [chemistId], references: [id])

  meeting Meeting? @relation(fields: [meetingId], references: [id])
}

model Activity {
  id Int @id @default(autoincrement())

  mrId Int

  activityType String

  title String

  description String?

  activityDate DateTime

  status String @default("PENDING")

  createdAt DateTime @default(now())

  mr MR @relation(fields: [mrId], references: [id])
}

model Lead {
  id Int @id @default(autoincrement())

  leadCode String @unique

  name String

  type String

  mobile String?

  email String?

  address String?

  territory String?

  source String?

  status String @default("NEW")

  assignedMrId Int?

  createdAt DateTime @default(now())

  assignedMr MR? @relation(fields: [assignedMrId], references: [id])
}

model LeaveRequest {
  id Int @id @default(autoincrement())

  mrId Int

  leaveType String

  fromDate DateTime

  toDate DateTime

  reason String?

  status String @default("PENDING")

  appliedAt DateTime @default(now())

  mr MR @relation(fields: [mrId], references: [id])
}

model ExpenseClaim {
  id Int @id @default(autoincrement())

  mrId Int

  expenseType String

  amount Decimal

  expenseDate DateTime

  description String?

  receiptUrl String?

  status String @default("PENDING")

  submittedAt DateTime @default(now())

  mr MR @relation(fields: [mrId], references: [id])
}

model Notification {
  id Int @id @default(autoincrement())

  mrId Int

  title String

  message String

  type String

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  mr MR @relation(fields: [mrId], references: [id])
}
